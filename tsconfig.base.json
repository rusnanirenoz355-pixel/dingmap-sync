{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "baseUrl": ".",
    "paths": {
      "@dingmap-sync/shared": ["packages/shared/index.ts"],
      "@dingmap-sync/shared/*": ["packages/shared/*"],
      "@dingmap-sync/sources/*": ["packages/sources/*"],
      "@dingmap-sync/normalizer/*": ["packages/normalizer/*"],
      "@dingmap-sync/dingmap/*": ["packages/dingmap/*"],
      "@dingmap-sync/browser-controller/*": ["packages/browser-controller/*"]
    }
  }
}
