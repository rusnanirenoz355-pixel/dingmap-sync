{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "types": ["node", "vitest/globals"]
  },
  "include": [
    "apps/dashboard/**/*.ts",
    "apps/dashboard/**/*.tsx",
    "apps/dashboard/next-env.d.ts",
    "packages/**/*.ts",
    "tests/**/*.ts"
  ],
  "exclude": ["node_modules", ".next", "**/.next/**", "dist", "build", "coverage"]
}
