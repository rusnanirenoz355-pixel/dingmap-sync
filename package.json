{
  "name": "dingmap-sync",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "cd apps/dashboard && next dev",
    "setup": "tsx packages/db/migrate.ts && playwright install chromium",
    "db:migrate": "tsx packages/db/migrate.ts",
    "db:seed": "tsx packages/db/seed.ts",
    "playwright:install": "playwright install chromium",
    "check": "tsc -p tsconfig.check.json --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "verify": "tsc -p tsconfig.check.json --noEmit && eslint . && vitest run",
    "format": "prettier --check .",
    "dingmap:inspect": "tsx packages/browser-controller/dingmap-inspect.ts"
  },
  "dependencies": {
    "exceljs": "^4.4.0",
    "lucide-react": "^0.468.0",
    "next": "^15.0.0",
    "playwright": "^1.48.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sqlite": "^5.1.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.0",
    "eslint": "^9.0.0",
    "postcss": "^8.4.0",
    "prettier": "^3.3.0",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.0.0"
  }
}
